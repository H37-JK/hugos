{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
    {{ range .Data.Pages }}
    {{ if .Permalink }}
    <url>
        <!-- .RelPermalink이 아닌 .Permalink를 써야 절대주소가 나옵니다 -->
        <loc>{{ .Permalink }}</loc>
        <lastmod>{{ .Lastmod.Format "2006-01-02T15:04:05+09:00" }}</lastmod>
    </url>
    {{ end }}
    {{ end }}
</urlset>